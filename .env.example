# Copy to .env and fill in. Never commit .env.

# Client auth: the Android app sends this in the X-API-Key header
LENS_API_KEY=change-me

# Anthropic (vision + agent)
LENS_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (tts-1 streaming)
LENS_OPENAI_API_KEY=sk-...

# TTS provider: "kokoro" runs locally (fast, no key needed), "openai" uses tts-1
LENS_TTS_PROVIDER=kokoro

# Memory (Phase 2): pgvector via `docker compose up -d` in backend/.
# Set empty to disable memory entirely.
# LENS_DATABASE_URL=postgresql://lens:lens@localhost:5433/lens
# LENS_STORAGE_DIR=./data

# Optional overrides (defaults shown)
# LENS_VLM_MODEL=claude-sonnet-4-6
# LENS_CAPTION_MODEL=claude-haiku-4-5-20251001
# LENS_TTS_MODEL=tts-1
# LENS_TTS_VOICE=alloy
# LENS_KOKORO_VOICE=af_heart
# LENS_WHISPER_MODEL=base
# LENS_MAX_IMAGE_EDGE=1280
